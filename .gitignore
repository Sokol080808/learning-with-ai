# --- ОС и редакторы ---
.DS_Store
*.swp
.idea/
.vscode/

# --- Python: кэши, виртуальные окружения ---
.pytest_cache/
__pycache__/
*.pyc
.venv/
**/.venv/
.mypy_cache/
.ruff_cache/
.hypothesis/
**/.hypothesis/

# --- Rust: артефакты сборки cargo ---
target/
**/target/

# --- Артефакты сборки C/C++ (CMake) ---
cpp/build/
caos/build/
*.o
*.obj
*.exe
compile_commands.json

# --- graphify ---
# Вложенные graphify-out (случайно создаются агентами в подкаталогах) игнорим целиком.
# Корневой коммитим выборочно: graph.json + GRAPH_REPORT.md + wiki/ (остальное — graph.html,
# cache/, manifest.json, cost.json, служебные .graphify_* — машинно-зависимое, в git не идёт).
**/graphify-out/**
!/graphify-out/graph.json
!/graphify-out/GRAPH_REPORT.md
!/graphify-out/wiki/
!/graphify-out/wiki/**

# --- learning-logs: данные диалогов локальные, в git не идут (README в корне отслеживается).
# Префикс **/ ловит learning-logs в ЛЮБОЙ папке: capture-хук иногда пишет в подкаталог
# (напр. rust/learning-logs/, когда cwd был внутри rust/), а не только в корневой learning-logs/. ---
**/learning-logs/journal.jsonl
**/learning-logs/journal-*.md
**/learning-logs/.last_captured
