# --- graphify ---
# Вложенные graphify-out (случайно создаются агентами в подкаталогах) игнорим целиком.
# Корневой коммитим выборочно: graph.json + GRAPH_REPORT.md + wiki/ (остальное — graph.html,
# cache/, manifest.json, cost.json, служебные .graphify_* — машинно-зависимое, в git не идёт).
**/graphify-out/**
!/graphify-out/graph.json
!/graphify-out/GRAPH_REPORT.md
!/graphify-out/wiki/
!/graphify-out/wiki/**

# --- learning-logs: данные диалогов локальные, в git не идут (README отслеживается) ---
learning-logs/journal.jsonl
learning-logs/journal-*.md
learning-logs/.last_captured
